{
  "name": "@sito/dashboard-app",
  "private": false,
  "version": "0.0.89",
  "type": "module",
  "description": "UI Library with prefab components",
  "main": "dist/dashboard-app.cjs",
  "module": "dist/dashboard-app.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "theme.css"
  ],
  "homepage": "https://github.com/sito8943/-sito-dashboard-app#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sito8943/-sito-dashboard-app.git"
  },
  "bugs": {
    "url": "https://github.com/sito8943/-sito-dashboard-app/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dashboard-app.js",
      "require": "./dist/dashboard-app.cjs"
    },
    "./theme.css": "./theme.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 && prettier --check . && pnpm run depcheck",
    "lint:fix": "eslint --fix . --report-unused-disable-directives --max-warnings 0 && prettier --write .",
    "docs:check": "node ./scripts/check-docs.mjs",
    "depcheck": "node ./scripts/depcheck.cjs .",
    "test": "NODE_OPTIONS=--max-old-space-size=6144 vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "keywords": [
    "sito",
    "dashboard",
    "components"
  ],
  "author": "sito8943",
  "license": "MIT",
  "engines": {
    "node": "^22.13.0"
  },
  "peerDependencies": {
    "@fortawesome/fontawesome-svg-core": ">=7.0.0 <8",
    "@fortawesome/free-brands-svg-icons": ">=7.0.0 <8",
    "@fortawesome/free-regular-svg-icons": ">=7.0.0 <8",
    "@fortawesome/free-solid-svg-icons": ">=7.0.0 <8",
    "@fortawesome/react-fontawesome": ">=3.1.1 <4",
    "@supabase/supabase-js": ">=2.100.0 <3",
    "@tanstack/react-query": ">=5.83.0 <6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": ">=7.61.1 <8"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@fortawesome/fontawesome-svg-core": "7.0.0",
    "@fortawesome/free-brands-svg-icons": "7.0.0",
    "@fortawesome/free-regular-svg-icons": "7.0.0",
    "@fortawesome/free-solid-svg-icons": "7.0.0",
    "@fortawesome/react-fontawesome": "3.4.0",
    "@storybook/addon-a11y": "8.4.7",
    "@storybook/addon-essentials": "8.4.7",
    "@storybook/addon-interactions": "8.4.7",
    "@storybook/react": "8.4.7",
    "@storybook/react-vite": "8.4.7",
    "@supabase/supabase-js": "2.100.0",
    "@tailwindcss/vite": "4.1.11",
    "@tanstack/react-query": "5.83.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/node": "20.8.10",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "3.7.2",
    "depcheck": "1.4.7",
    "eslint": "9.0.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.1",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "prettier": "3.3.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.61.1",
    "storybook": "8.6.18",
    "tailwindcss": "4.1.11",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.56.0",
    "vite": "6.4.2",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-lib-inject-css": "1.3.0",
    "vitest": "^3.2.1"
  },
  "dependencies": {
    "@sito/dashboard": "^0.1.0",
    "@use-gesture/react": "^10.3.1",
    "some-javascript-utils": "^0.10.10"
  },
  "packageManager": "pnpm@10.34.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
