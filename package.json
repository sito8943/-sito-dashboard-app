{
  "name": "@sito/dashboard-app",
  "private": false,
  "version": "0.1.1",
  "type": "module",
  "description": "UI Library with prefab components",
  "main": "dist/dashboard-app.cjs",
  "module": "dist/dashboard-app.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "theme.css"
  ],
  "homepage": "https://github.com/sito8943/-sito-dashboard-app#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sito8943/-sito-dashboard-app.git"
  },
  "bugs": {
    "url": "https://github.com/sito8943/-sito-dashboard-app/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dashboard-app.js",
      "require": "./dist/dashboard-app.cjs"
    },
    "./theme.css": "./theme.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "oxlint --type-aware --max-warnings 0",
    "lint:fix": "oxlint --type-aware --fix --max-warnings 0",
    "docs:check": "node ./scripts/check-docs.mjs",
    "deps:check": "knip --dependencies",
    "test": "NODE_OPTIONS=--max-old-space-size=6144 vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "full": "pnpm run lint && pnpm run format:check && pnpm run deps:check && pnpm run docs:check && pnpm run build && pnpm run test",
    "prepare": "husky"
  },
  "keywords": [
    "sito",
    "dashboard",
    "components"
  ],
  "author": "sito8943",
  "license": "MIT",
  "engines": {
    "node": "^22.13.0"
  },
  "peerDependencies": {
    "@fortawesome/fontawesome-svg-core": ">=7.0.0 <8",
    "@fortawesome/free-regular-svg-icons": ">=7.0.0 <8",
    "@fortawesome/free-solid-svg-icons": ">=7.0.0 <8",
    "@fortawesome/react-fontawesome": ">=3.1.1 <4",
    "@supabase/supabase-js": ">=2.100.0 <3",
    "@tanstack/react-query": ">=5.83.0 <6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": ">=7.61.1 <8"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@fortawesome/fontawesome-svg-core": "7.0.0",
    "@fortawesome/free-regular-svg-icons": "7.0.0",
    "@fortawesome/free-solid-svg-icons": "7.0.0",
    "@fortawesome/react-fontawesome": "3.4.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@supabase/supabase-js": "2.100.0",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-query": "5.83.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/typescript6": "^6.0.2",
    "@vitejs/plugin-react": "6.0.3",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "knip": "6.25.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.61.1",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "vite-plugin-lib-inject-css": "1.3.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@sito/dashboard": "^0.1.2",
    "@use-gesture/react": "^10.3.1",
    "some-javascript-utils": "^0.10.10"
  },
  "packageManager": "pnpm@10.34.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
